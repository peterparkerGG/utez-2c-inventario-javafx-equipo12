<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.inventario.FormController"
      spacing="10" prefWidth="350" prefHeight="350">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <Label fx:id="lblTitulo" text="Añadir Producto" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCodigo" promptText="Ej: PROD001" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNombre" promptText="Nombre del producto" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Precio:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrecio" promptText="Ej: 25.50" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Stock:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtStock" promptText="Ej: 100" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Categoría:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCategoria" promptText="Ej: Abarrotes" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Guardar" onAction="#onGuardar" prefWidth="100" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="Cancelar" onAction="#onCancelar" prefWidth="100"/>
    </HBox>
</VBox>
