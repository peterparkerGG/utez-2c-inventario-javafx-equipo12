<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.inventario.controlador.MainController"
      spacing="10" prefWidth="750" prefHeight="500">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <Label text="Inventario de Productos" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar:"/>
        <TextField fx:id="txtBusqueda" promptText="Buscar por código o nombre..." prefWidth="250"/>
        <Label text="Ordenar:"/>
        <ComboBox fx:id="cmbOrdenar" prefWidth="200"/>
    </HBox>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
            <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
            <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Nuevo" onAction="#onNuevo" prefWidth="100" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="Editar" onAction="#onEditar" prefWidth="100" style="-fx-background-color: #8800ff; -fx-text-fill: white;"/>
        <Button text="Eliminar" onAction="#onEliminar" prefWidth="100" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="Recargar" onAction="#onRecargar" prefWidth="100" style="-fx-background-color: #007bff; -fx-text-fill: white;"/>
    </HBox>
</VBox>

